{
  "name": "p2p-lockstep-kit-ui",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json && node ./scripts/postbuild.mjs",
    "build:pages": "vite build --config vite.pages.config.ts",
    "preview": "vite preview",
    "preview:pages": "vite preview --outDir dist-pages",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier -w ."
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/qrcode": "^1.5.5",
    "prettier": "^3.3.1",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "p2p-lockstep-kit-network": "^0.1.2",
    "p2p-lockstep-kit-session": "^0.1.9",
    "qrcode": "^1.5.4"
  }
}
