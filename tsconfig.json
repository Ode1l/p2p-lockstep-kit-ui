{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "declaration": false,
    "sourceMap": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "p2p-lockstep-kit-ui": ["./src/index.ts"],
      "p2p-lockstep-kit-session": [
        "../p2p-lockstep-kit-session/dist/session/index.d.ts"
      ]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "vite.config.ts"]
}
